{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (node)",
      "runtimeExecutable": "node",
      "runtimeArgs": [".claude/server.js"],
      "port": 8081
    },
    {
      "name": "Static Site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "page", "-l", "8080"],
      "port": 8080
    },
    {
      "name": "Static Site (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "page"],
      "port": 8080
    }
  ]
}
